@{
    ViewBag.Title = "Password Reset Sent";
    <link rel="stylesheet" href="~/css/Account.css" />
}

<div class="account-container">
    <div class="account-box text-center">
        <h2 class="mb-4">Password Reset Email Sent</h2>
        <p>A link to reset your password has been sent to your email address. Please check your inbox.</p>

        <a href="@Url.Action("Login", "Account")" class="btn btn-primary mt-3">Back to Login</a>
    </div>
</div>