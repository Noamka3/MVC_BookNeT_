@model IEnumerable<_BookNeT_.Models.Users>
<head>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>

<div class="container mt-5" style="background-color: #f3f2ec; padding: 20px; border-radius: 10px;">
    <!-- Feedback Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" id="feedbackMessage" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" id="feedbackMessage" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Users Table -->
    <div class="table-responsive shadow rounded">
        <table class="table table-bordered table-hover text-center align-middle" style="background-color: #f3f2ec;">
            <thead class="table-dark" style="background-color: #333333;">
            <tr>
                <th style="color: black;">@Html.DisplayNameFor(model => model.FirstOrDefault().FirstName)</th>
                <th style="color: black;">@Html.DisplayNameFor(model => model.FirstOrDefault().LastName)</th>
                <th style="color: black;">@Html.DisplayNameFor(model => model.FirstOrDefault().Email)</th>
                <th style="color: black;">@Html.DisplayNameFor(model => model.FirstOrDefault().Phone)</th>
                <th style="color: black;">@Html.DisplayNameFor(model => model.FirstOrDefault().Role)</th>
                <th style="color: black;">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => user.FirstName)</td>
                    <td>@Html.DisplayFor(modelItem => user.LastName)</td>
                    <td>@Html.DisplayFor(modelItem => user.Email)</td>
                    <td>@Html.DisplayFor(modelItem => user.Phone)</td>
                    <td>@Html.DisplayFor(modelItem => user.Role)</td>
                    <td>
                        <button class="btn btn-info btn-sm userDetailsBtn m-1" data-id="@user.UserID">
                            <i class="fas fa-eye"></i> Details
                        </button>
                        <button class="btn btn-warning btn-sm userEditsBtn m-1" data-id="@user.UserID">
                            <i class="fas fa-edit"></i> Edit
                        </button>
                        <a href="@Url.Action("Delete", "Users", new { id = user.UserID })" class="btn btn-danger btn-sm m-1" onclick="return confirm('Are you sure you want to delete this user?')">
                            <i class="fas fa-trash"></i> Delete
                        </a>
                        <a href="@Url.Action("ChangeRole", "Users", new { id = user.UserID })" class="btn btn-secondary btn-sm m-1">
                            <i class="fas fa-user-tag"></i> Change Role
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal for Details -->
<div class="modal fade" id="userDetailsModal" tabindex="-1" aria-labelledby="userDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="background-color: #f3f2ec;">
            <div class="modal-header">
                <h3 class="modal-title" id="userDetailsModalLabel">User Information</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="userDetailsContent">
                <div class="container p-3">
                    <div class="row">
                        <div class="col-md-12">
                            <dl class="row">
                                <dt class="col-sm-4"> First Name:</dt>
                                <dd class="col-sm-8">@Model.FirstOrDefault().FirstName</dd>

                                <dt class="col-sm-4">Last Name:</dt>
                                <dd class="col-sm-8">@Model.FirstOrDefault().LastName</dd>

                                <dt class="col-sm-4">Email Address:</dt>
                                <dd class="col-sm-8">@Model.FirstOrDefault().Email</dd>

                                <dt class="col-sm-4">Phone Number:</dt>
                                <dd class="col-sm-8">@Model.FirstOrDefault().Phone</dd>

                                <dt class="col-sm-4">Role:</dt>
                                <dd class="col-sm-8">@Model.FirstOrDefault().Role</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Edits -->
<div class="modal fade" id="userEditsModal" tabindex="-1" aria-labelledby="userEditsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="background-color: #f3f2ec;">
            <div class="modal-header">
                <h3 class="modal-title" id="userEditsModalLabel">Edit User Details</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="userEditsContent"></div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f3f2ec;
    }

    h2 {
        color: black;
    }

    .table thead th {
        background-color: #f3f2ec;
        color: black;
    }

    .table tbody td {
        background-color: #f3f2ec;
    }

    .btn {
        background-color: #f3f2ec;
        color: black;
        border: 1px solid black;
    }

    .btn:hover {
        background-color: #ddd;
        color: black;
    }

    /* Modal Styles */
    .modal-content {
        background-color: #f3f2ec !important;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    .modal-header {
        background-color: #f3f2ec;
        border-bottom: 1px solid #ddd;
        border-radius: 10px 10px 0 0;
    }

    /* Form Field Styles */
    .form-control {
        background-color: #f3f2ec !important;
        border: 1px solid #ddd;
    }

    .form-control:focus {
        background-color: #f3f2ec !important;
        border-color: #666;
        box-shadow: none;
    }

    /* Alert Styles */
    .alert {
        background-color: #f3f2ec !important;
        border: 1px solid #ddd;
        border-radius: 10px;
        margin-bottom: 20px;
        padding: 15px;
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 1050;
        animation: fadeOut 5s forwards;
        width: auto;
        min-width: 300px;
    }

    .alert-success {
        border-left: 5px solid #28a745;
    }

    .alert-danger {
        border-left: 5px solid #dc3545;
    }
    
</style>

@section Scripts {
    <script>
        // Load Edit User Content
        $(document).on('click', '.userEditsBtn', function () {
            var userId = $(this).data('id');
            $.get('/Users/Edits/' + userId, function (data) {
                $('#userEditsContent').html(data);
                var modal = new bootstrap.Modal(document.getElementById('userEditsModal'));
                modal.show();
            });
        });

        // Load User Details Content
        $(document).on('click', '.userDetailsBtn', function () {
            var userId = $(this).data('id');
            $.get('/Users/Details/' + userId, function (data) {
                $('#userDetailsContent').html(data);
                var modal = new bootstrap.Modal(document.getElementById('userDetailsModal'));
                modal.show();
            });
        });

        // Handle Modal Close
        $(document).ready(function() {
            // Auto-hide alerts after 5 seconds
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);

            // Close button handling
            $('.btn-close').click(function() {
                var modal = bootstrap.Modal.getInstance(this.closest('.modal'));
                if (modal) {
                    modal.hide();
                }
                $(this).closest('.alert').fadeOut('slow');
            });
        });
    </script>
}