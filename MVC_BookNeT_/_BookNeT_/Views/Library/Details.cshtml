        padding: 8px 12px;
        font-size: 14px;
        font-weight: bold;
        text-align: center;
        border-radius: 6px;
        border: none;
        transition: all 0.3s ease;
    }

    .dropdown-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        background-color: #f9f9f9;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 10px 0;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        z-index: 1050;
        min-width: 150px;
        width: 100%;
    }

    .dropdown-item {
        padding: 10px 20px; /* ריווח פנימי */
        font-size: 14px; /* גודל טקסט */
        color: #0078a8; /* צבע טקסט */
        text-align: center; /* יישור טקסט */
        transition: background-color 0.2s ease, color 0.2s ease; /* אפקט מעבר חלק */
