        align-items: center;
        justify-content: center;
        gap: 8px; /* רווח בין האייקון לטקסט */
    }

    /* עיצוב אייקונים */
    .dropdown-item i {
        font-size: 16px;
        color: #0078a8; /* צבע תואם לטקסט */
    }

    /* אפקט ריחוף */
    .dropdown-item:hover {
        background-color: #f0f8ff; /* רקע כחול בהיר */
        color: #0056b3; /* צבע כהה יותר */
