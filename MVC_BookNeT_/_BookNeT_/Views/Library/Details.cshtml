<!-- סקריפט ראשון - טיפול בדירוג כוכבים -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const stars = document.querySelectorAll('.stars i');
        const ratingInput = document.getElementById('selectedRating');

        stars.forEach(star => {
            star.addEventListener('mouseover', function () {
                const rating = this.getAttribute('data-rating');
                highlightStars(rating);
            });

            star.addEventListener('click', function () {
                const rating = this.getAttribute('data-rating');
                ratingInput.value = rating;
                highlightStars(rating);
            });
        });

        document.querySelector('.stars')?.addEventListener('mouseout', function () {
            const selectedRating = ratingInput.value || 0;
            highlightStars(selectedRating);
        });

        function highlightStars(rating) {
            stars.forEach(star => {
                const starRating = star.getAttribute('data-rating');
                if (starRating <= rating) {
                    star.classList.remove('far');
                    star.classList.add('fas');
                    star.style.transform = 'scale(1.1)';
                } else {
                    star.classList.remove('fas');
                    star.classList.add('far');
                    star.style.transform = 'scale(1)';
                }
            });
        }
    });
</script>
<script>
    // פונקציות לטיפול בעגלה
    function updateCartIcon() {
        $.get('@Url.Action("GetCartCount", "ShoppingCart")', function(response) {
            const countElement = $('.cart-count');
            const count = response.count || 0;

            countElement.text(count);
            countElement.show();

            countElement.css('animation', 'none');
            countElement[0].offsetHeight; // trigger reflow
            countElement.css('animation', 'pop 0.3s ease');
        });
    }

    // טיפול בהוספה לעגלה
    $(document).ready(function() {
        $('.add-to-cart-form').on('submit', function(e) {
            e.preventDefault();
            const form = $(this);

            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function(response) {
                    if (response.success) {
                        updateCartIcon();
                        alert('Item added to cart successfully!');
                    } else {
                        alert(response.message || 'Failed to add item to cart.');
                    }
                },
                error: function() {
                    alert('Error communicating with server.');
                }
            });
        });

        // עדכון ראשוני של העגלה
        updateCartIcon();
    });

    function showModal(title, content) {
        $('#customModal').remove();

        const modalHtml = `
        <div class="custom-modal" id="customModal">
            <div class="custom-modal-dialog">
                <div class="custom-modal-content">
                    <div class="custom-modal-header">
                        <h5 class="custom-modal-title">${title}</h5>
                        <button type="button" class="custom-modal-close" onclick="closeCustomModal()">&times;</button>
                    </div>
                    <div class="custom-modal-body">${content}</div>
                </div>
            </div>
        </div>
    `;
        $('body').append(modalHtml);

        // הצגת המודל
        setTimeout(() => {
            $('#customModal').addClass('show');
        }, 50);
    }


    function closeCustomModal() {
        const modal = $('#customModal');
        modal.removeClass('show');
        setTimeout(() => {
            modal.remove();
        }, 300);
    }

    // טיפול בלחיצה על כפתור הצגת רשימת המתנה
    $(document).on('click', '.show-waiting-list-btn', function () {
        const bookId = $(this).data('book-id');

        $.get('/Library/GetWaitingListInfo', { bookId: bookId })
            .done(function (response) {
                if (response.success) {
                    let modalContent = `
                    <div class="waiting-list-info">
                        <div class="waiting-count">
                            <h4>Book Availability Status</h4>
                            <p><i class="fas fa-users"></i> Currently ${response.waitingCount} ${response.waitingCount === 1 ? 'person is' : 'people are'} waiting</p>
                        </div>
                        <div class="waiting-list-details">
                            <h5>Expected Waiting Times:</h5>
                            <ul class="list-group">
                `;

                    response.waitingList.forEach(user => {
                        const estimatedDays = user.EstimatedAvailability;
                        modalContent += `
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Queue Position ${user.Position}:</strong> ${user.UserName}
                            </div>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span class="estimated-time">
                                    <i class="far fa-clock"></i> Available in ${estimatedDays} days
                                </span>
                                ${response.isAdmin ? `
                                    <button onclick="removeUserFromWaitingList(${bookId}, ${user.UserID})"
                                            class="remove-user-btn"
                                            title="Remove user">
                                        <i class="fas fa-times"></i>
                                    </button>
                                ` : ''}
                            </div>
                        </li>
                    `;
                    });

                    modalContent += `
                            </ul>
                            <div class="waiting-note mt-3">
                                <small style="color: #000;">
                                    <i class="fas fa-info-circle"></i> Standard borrowing period is 30 days. Actual availability may vary.
                                </small>
                            </div>
                        </div>
                    </div>
                `;

                    showModal('Waiting List Information', modalContent);
                } else {
                    alert(response.message || 'Failed to fetch waiting list.');
                }
            })
            .fail(function () {
                alert('Error communicating with the server.');
            });
    });

    // סגירת המודל בלחיצה מחוץ לתוכן
    $(document).on('click', '.custom-modal', function(e) {
        if ($(e.target).hasClass('custom-modal')) {
            closeCustomModal();
        }
    });

    //  פונקציה למחיקת משתמש
    function removeUserFromWaitingList(bookId, userId) {
        if (confirm('Are you sure you want to remove this user from the waiting list?')) {
            $.ajax({
                url: '/Library/RemoveUserFromWaitingList',
                type: 'POST',
                data: {
                    bookId: bookId,
                    userId: userId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        // רענון הרשימה אחרי מחיקה
                        $('.show-waiting-list-btn[data-book-id="' + bookId + '"]').click();
                    } else {
                        alert(response.message || 'Failed to remove user from waiting list.');
                    }
                },
                error: function() {
                    alert('Error communicating with server.');
                }
            });
            function updateWaitingList(bookId) {
                $.get('/Library/GetWaitingListInfo', { bookId: bookId })
                    .done(function (response) {
                        if (response.success) {
                            const waitingList = response.waitingList;
                            const listItems = waitingList.map(user => `
                    <li>
                        Queue Position ${user.Position}: ${user.UserName} (Available in ${user.EstimatedAvailability} days)
                    </li>
                `).join('');
                            $('#waitingListContainer').html(listItems);
                        } else {
                            alert(response.message || 'Failed to update waiting list.');
                        }
                    });
            }

            function removeUserFromWaitingList(bookId, userId) {
                if (confirm('Are you sure you want to remove this user from the waiting list?')) {
                    $.ajax({
                        url: '/Library/RemoveUserFromWaitingList',
                        type: 'POST',
                        data: {
                            bookId: bookId,
                            userId: userId,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                // רענון הרשימה אחרי מחיקה
                                $('.show-waiting-list-btn[data-book-id="' + bookId + '"]').click();
                            } else {
                                alert(response.message || 'Failed to remove user from waiting list.');
                            }
                        },
                        error: function() {
                            alert('Error communicating with server.');
                        }
                    });
                }
            }

        }
    }
</script>