        margin: 0; /* הסרת מרווחים חיצוניים */
    }

    .btn.add-to-cart-btn:hover,
    .btn.purchase-btn:hover,
    .btn.borrow-btn:hover {
        background: #dcdcdc; /* אפור בהיר בריחוף */
        transform: scale(1.05); /* אפקט קל של הגדלה */
        cursor:
            pointer;
    }


    /* סגנון כללי לכפתורים */
