@using _BookNeT_.Models

@section styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Home.css" />
}

<!-- ============ HERO ============ -->
<section class="hero">
    <div class="hero__overlay"></div>
    <div class="hero__content">
        <span class="hero__eyebrow">Your Advanced Digital Library</span>
        <h1 class="hero__title">Discover Your Next<br><em>Great Read</em></h1>
        <p class="hero__sub">Thousands of books to borrow or buy. Personalized picks, a vibrant readers' community, and a seamless digital experience.</p>
        <div class="hero__actions">
            <a href="@Url.Action("Index", "Library")" class="btn-hero btn-hero--primary">
                <i class="fas fa-book-open"></i> Browse Library
            </a>
            @if (Session["Email"] == null)
            {
                <a href="@Url.Action("Register", "Account")" class="btn-hero btn-hero--outline">
                    Join for Free
                </a>
            }
        </div>
    </div>
    <div class="hero__scroll">
        <span></span>
    </div>
</section>

<!-- ============ STATS BAR ============ -->
<section class="stats">
    <div class="stats__grid">
        <div class="stats__item">
            <span class="stats__num">@(ViewBag.BookCount ?? 0)<span class="stats__plus">+</span></span>
            <span class="stats__label">Books Available</span>
        </div>
        <div class="stats__divider"></div>
        <div class="stats__item">
            <span class="stats__num">@(ViewBag.UserCount ?? 0)<span class="stats__plus">+</span></span>
            <span class="stats__label">Active Readers</span>
        </div>
        <div class="stats__divider"></div>
        <div class="stats__item">
            <span class="stats__num">@(ViewBag.GenreCount ?? 0)<span class="stats__plus">+</span></span>
            <span class="stats__label">Genres</span>
        </div>
    </div>
</section>

<!-- ============ FEATURES ============ -->
<section class="features">
    <div class="section-header">
        <span class="section-tag">Why BookNeT</span>
        <h2 class="section-title">Everything You Need to Read</h2>
    </div>
    <div class="features__grid">
        <div class="feature-card">
            <div class="feature-card__icon">
                <i class="fas fa-layer-group"></i>
            </div>
            <h3>Huge Collection</h3>
            <p>From timeless classics to new releases — fiction, science, history, and more. Always growing.</p>
        </div>
        <div class="feature-card feature-card--accent">
            <div class="feature-card__icon">
                <i class="fas fa-hand-holding-heart"></i>
            </div>
            <h3>Borrow or Buy</h3>
            <p>Flexible plans — borrow for a limited time or purchase to keep forever. Your choice.</p>
        </div>
        <div class="feature-card">
            <div class="feature-card__icon">
                <i class="fas fa-star"></i>
            </div>
            <h3>Smart Picks</h3>
            <p>Personalized recommendations based on your reading history and favorite genres.</p>
        </div>
    </div>
</section>

<!-- ============ FEATURED BOOKS ============ -->
@if (ViewBag.FeaturedBooks != null && ((IEnumerable<Books>)ViewBag.FeaturedBooks).Any())
{
    <section class="featured">
        <div class="section-header">
            <span class="section-tag">Catalog</span>
            <h2 class="section-title">Featured Books</h2>
        </div>
        <div class="books-grid">
            @foreach (Books book in (IEnumerable<Books>)ViewBag.FeaturedBooks)
            {
                <a href="@Url.Action("Details", "Library", new { id = book.BookID })" class="book-card">
                    <div class="book-card__cover">
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" alt="@book.Title" />
                        }
                        else
                        {
                            <div class="book-card__placeholder">
                                <i class="fas fa-book"></i>
                            </div>
                        }
                        <div class="book-card__badge">
                            @if (book.IsBorrowable == true)
                            {
                                <span class="badge--borrow">Borrow</span>
                            }
                            else
                            {
                                <span class="badge--buy">Buy</span>
                            }
                        </div>
                    </div>
                    <div class="book-card__info">
                        <p class="book-card__genre">@(book.Genre ?? "General")</p>
                        <h4 class="book-card__title">@book.Title</h4>
                        <p class="book-card__author">@book.Author</p>
                        <div class="book-card__price">
                            @if (book.BorrowPrice.HasValue)
                            {
                                <span>@book.BorrowPrice.Value.ToString("0.00") &#8362;</span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
        <div class="featured__cta">
            <a href="@Url.Action("Index", "Library")" class="btn-view-all">
                View All Books <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </section>
}

<!-- ============ CART ICON ============ -->
@if (Session["Email"] != null)
{
    <div class="floating-cart">
        <a href="@Url.Action("Index", "ShoppingCart")" class="floating-cart__link">
            <i class="fas fa-shopping-cart"></i>
            @if ((int)(ViewBag.CartCount ?? 0) > 0)
            {
                <span class="floating-cart__count">@ViewBag.CartCount</span>
            }
        </a>
    </div>
}

<!-- ============ REVIEWS ============ -->
<section class="reviews">
    <div class="section-header">
        <span class="section-tag">Community</span>
        <h2 class="section-title">What Readers Say</h2>
    </div>

    @if (ViewBag.Feedbacks != null && ((List<_BookNeT_Project.Controllers.FeedbackViewModel>)ViewBag.Feedbacks).Any())
    {
        <div class="reviews__grid">
            @foreach (var feedback in (List<_BookNeT_Project.Controllers.FeedbackViewModel>)ViewBag.Feedbacks)
            {
                <div class="review-card">
                    <div class="review-card__header">
                        <div class="review-card__avatar">
                            @feedback.UserName.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <strong class="review-card__name">@feedback.UserName</strong>
                            <small class="review-card__date">@feedback.FeedbackDate.ToString("MMM dd, yyyy")</small>
                        </div>
                        @if (Session["Role"] != null && Session["Role"].ToString() == "Admin")
                        {
                            <form action="@Url.Action("RemoveFeedback", "Home")" method="post" class="review-card__delete">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="feedbackId" value="@feedback.FeedbackID" />
                                <button type="submit" title="Delete"><i class="fas fa-trash-alt"></i></button>
                            </form>
                        }
                    </div>
                    <div class="review-card__stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="@(i <= feedback.Rating ? "fas" : "far") fa-star"></i>
                        }
                    </div>
                    <p class="review-card__text">@feedback.FeedbackText</p>
                </div>
            }
        </div>
    }
    else
    {
        <p class="reviews__empty">No reviews yet. Be the first to share your experience!</p>
    }

    <!-- Leave a Review Form -->
    @if (Session["Email"] != null)
    {
        <div class="review-form">
            <h3 class="review-form__title">Leave a Review</h3>
            <form action="@Url.Action("AddFeedback", "Home")" method="post">
                <div class="review-form__stars" id="starPicker">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="far fa-star" data-rating="@i"></i>
                    }
                    <input type="hidden" name="Rating" id="selectedRating" value="0" />
                </div>
                <textarea name="feedbackText" class="review-form__textarea" placeholder="Share your experience with BookNeT..." required></textarea>
                <button type="submit" class="review-form__submit">
                    <i class="fas fa-paper-plane"></i> Submit Review
                </button>
            </form>
        </div>
    }
    else
    {
        <div class="reviews__login">
            <i class="fas fa-lock"></i>
            <p><a href="@Url.Action("Login", "Account")">Log in</a> to leave a review</p>
        </div>
    }
</section>

<!-- ============ CTA BANNER ============ -->
@if (Session["Email"] == null)
{
    <section class="cta">
        <div class="cta__content">
            <h2>Start Reading Today</h2>
            <p>Join thousands of readers and access our full library in seconds.</p>
            <a href="@Url.Action("Register", "Account")" class="btn-hero btn-hero--primary">
                Create Free Account
            </a>
        </div>
    </section>
}

<script>
    document.querySelectorAll('#starPicker .fa-star').forEach(star => {
        star.addEventListener('click', function () {
            const rating = parseInt(this.dataset.rating);
            document.getElementById('selectedRating').value = rating;
            document.querySelectorAll('#starPicker .fa-star').forEach((s, idx) => {
                s.classList.toggle('fas', idx < rating);
                s.classList.toggle('far', idx >= rating);
            });
        });
        star.addEventListener('mouseover', function () {
            const rating = parseInt(this.dataset.rating);
            document.querySelectorAll('#starPicker .fa-star').forEach((s, idx) => {
                s.classList.toggle('fas', idx < rating);
                s.classList.toggle('far', idx >= rating);
            });
        });
    });
    document.getElementById('starPicker')?.addEventListener('mouseleave', function () {
        const saved = parseInt(document.getElementById('selectedRating').value) || 0;
        document.querySelectorAll('#starPicker .fa-star').forEach((s, idx) => {
            s.classList.toggle('fas', idx < saved);
            s.classList.toggle('far', idx >= saved);
        });
    });
</script>
