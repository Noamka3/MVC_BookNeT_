@model IEnumerable<_BookNeT_.Models.ShoppingCart>
<script src="https://www.paypal.com/sdk/js?client-id=@ViewBag.PayPalClientId&currency=ILS"></script>

<!-- SweetAlert2 -->
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.0.9/dist/sweetalert2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.0.9/dist/sweetalert2.min.js"></script>

<div class="ck-page">

    <!-- Progress Steps -->
    <div class="ck-steps">
        <div class="ck-steps__inner">
            <div class="ck-step done">
                <div class="ck-step__dot"><i class="fas fa-check"></i></div>
                <span>Cart</span>
            </div>
            <div class="ck-steps__line done"></div>
            <div class="ck-step active">
                <div class="ck-step__dot"><i class="fas fa-credit-card"></i></div>
                <span>Checkout</span>
            </div>
            <div class="ck-steps__line"></div>
            <div class="ck-step">
                <div class="ck-step__dot"><i class="fas fa-check-circle"></i></div>
                <span>Complete</span>
            </div>
        </div>
    </div>

    <!-- Alert -->
    @if (TempData["Message"] != null)
    {
        var message = TempData["Message"] as dynamic;
        <div class="ck-alert ck-alert--@message.Type">
            <i class="fas fa-@((message.Type == "success") ? "check-circle" : (message.Type == "error" ? "times-circle" : "info-circle"))"></i>
            @message.Text
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="ck-empty">
            <i class="fas fa-shopping-cart"></i>
            <p>Your cart is empty.</p>
            <a href="@Url.Action("Index", "Library")" class="ck-btn ck-btn--primary">Browse Library</a>
        </div>
        return;
    }

    <div class="ck-layout">

        <!-- Left: Order Summary -->
        <div class="ck-summary-col">
            <div class="ck-panel">
                <div class="ck-panel__head">
                    <h2><i class="fas fa-receipt"></i> Order Summary</h2>
                </div>
                <div class="ck-panel__body">

                    @foreach (var item in Model)
                    {
                        var price = (item.IsBorrow ? item.Books.BorrowPrice : item.Books.PurchasePrice).GetValueOrDefault();
                        var sub = price * item.Quantity;

                        <div class="ck-order-item">
                            <div class="ck-order-item__cover">
                                @if (!string.IsNullOrEmpty(item.Books.ImageUrl))
                                {
                                    <img src="@item.Books.ImageUrl" alt="@item.Books.Title" />
                                }
                                else
                                {
                                    <div class="ck-order-item__cover-ph"><i class="fas fa-book"></i></div>
                                }
                            </div>
                            <div class="ck-order-item__info">
                                <p class="ck-order-item__title">@item.Books.Title</p>
                                <p class="ck-order-item__meta">@item.Books.Author</p>
                                <div class="ck-order-item__tags">
                                    <span class="ck-tag ck-tag--@(item.IsBorrow ? "borrow" : "buy")">
                                        <i class="fas fa-@(item.IsBorrow ? "bookmark" : "shopping-bag")"></i>
                                        @(item.IsBorrow ? "Borrow" : "Purchase")
                                    </span>
                                    <span class="ck-tag ck-tag--qty">x@item.Quantity</span>
                                </div>
                            </div>
                            <div class="ck-order-item__price" dir="ltr">&#8362;@sub.ToString("F2")</div>
                        </div>
                    }

                    <div class="ck-summary-total">
                        <div class="ck-summary-total__row">
                            <span>Subtotal</span>
                            <span dir="ltr">&#8362;@ViewBag.TotalAmount</span>
                        </div>
                        <div class="ck-summary-total__row">
                            <span>Shipping</span>
                            <span class="ck-free">Free</span>
                        </div>
                        <div class="ck-summary-total__divider"></div>
                        <div class="ck-summary-total__row ck-summary-total__row--grand">
                            <span>Total</span>
                            <span dir="ltr">&#8362;@ViewBag.TotalAmount</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Payment -->
        <div class="ck-payment-col">
            @using (Html.BeginForm("ProcessPayment", "Payment", FormMethod.Post, new { id = "paymentForm" }))
            {
                @Html.AntiForgeryToken()

                <div class="ck-panel">
                    <div class="ck-panel__head">
                        <h2><i class="fas fa-lock"></i> Secure Payment</h2>
                    </div>
                    <div class="ck-panel__body">

                        <p class="ck-payment-intro">Choose your preferred payment method</p>

                        <!-- Credit Card -->
                        <button type="button" class="ck-pay-option" onclick="document.getElementById('ck-cc-modal').classList.add('open')">
                            <div class="ck-pay-option__icon ck-pay-option__icon--card">
                                <i class="fas fa-credit-card"></i>
                            </div>
                            <div class="ck-pay-option__info">
                                <strong>Credit / Debit Card</strong>
                                <span>Visa, Mastercard, Amex</span>
                            </div>
                            <i class="fas fa-chevron-right ck-pay-option__arrow"></i>
                        </button>

                        <div class="ck-pay-or"><span>or</span></div>

                        <!-- PayPal -->
                        <div class="ck-paypal-wrap">
                            <div class="ck-paypal-label">
                                <i class="fab fa-paypal"></i> Pay with PayPal
                            </div>
                            <div id="paypal-button-container"></div>
                        </div>

                        <div class="ck-back-link">
                            <a href="@Url.Action("Index", "ShoppingCart")" class="ck-btn ck-btn--ghost">
                                <i class="fas fa-arrow-left"></i> Back to Cart
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ===== CREDIT CARD MODAL ===== -->
<div id="ck-cc-modal" class="ck-modal-overlay">
    <div class="ck-modal">
        <!-- Visual Card Preview -->
        <div class="ck-card-preview">
            <div class="ck-card-preview__chip"><i class="fas fa-microchip"></i></div>
            <div class="ck-card-preview__number" id="preview-number">•••• •••• •••• ••••</div>
            <div class="ck-card-preview__bottom">
                <div>
                    <div class="ck-card-preview__label">Card Holder</div>
                    <div class="ck-card-preview__value" id="preview-name">FULL NAME</div>
                </div>
                <div>
                    <div class="ck-card-preview__label">Expires</div>
                    <div class="ck-card-preview__value" id="preview-expiry">MM/YY</div>
                </div>
            </div>
        </div>

        <h3 class="ck-modal__title">Enter Card Details</h3>

        <div class="ck-form-group">
            <label>Card Number</label>
            <div class="ck-input-wrap">
                <i class="fas fa-credit-card"></i>
                <input type="text" id="cardNumber" maxlength="19" placeholder="1234 5678 9012 3456"
                       oninput="formatCardNumber(this)" class="ck-input" />
            </div>
        </div>

        <div class="ck-form-group">
            <label>Cardholder Name</label>
            <div class="ck-input-wrap">
                <i class="fas fa-user"></i>
                <input type="text" id="cardHolderName" placeholder="JOHN DOE"
                       oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g,'').toUpperCase(); document.getElementById('preview-name').textContent = this.value || 'FULL NAME';"
                       class="ck-input" />
            </div>
        </div>

        <div class="ck-form-row">
            <div class="ck-form-group">
                <label>Expiry Date</label>
                <div class="ck-input-wrap">
                    <i class="fas fa-calendar"></i>
                    <input type="text" id="expiryDate" maxlength="5" placeholder="MM/YY"
                           oninput="formatExpiry(this)" class="ck-input" />
                </div>
            </div>
            <div class="ck-form-group">
                <label>CVV</label>
                <div class="ck-input-wrap">
                    <i class="fas fa-lock"></i>
                    <input type="text" id="cvv" maxlength="4" placeholder="•••"
                           oninput="this.value = this.value.replace(/\D/g,'')" class="ck-input" />
                </div>
            </div>
        </div>

        <div class="ck-modal__actions">
            <button type="button" onclick="document.getElementById('ck-cc-modal').classList.remove('open')" class="ck-btn ck-btn--ghost">
                Cancel
            </button>
            <button type="button" onclick="confirmPayment()" class="ck-btn ck-btn--primary">
                <i class="fas fa-lock"></i> Pay &#8362;@ViewBag.TotalAmount
            </button>
        </div>
    </div>
</div>
<div class="ck-modal-backdrop" onclick="document.getElementById('ck-cc-modal').classList.remove('open')"></div>

<style>
/* ============================================================
   CHECKOUT — Premium Design
   ============================================================ */

:root {
    --ck-primary:   #00B4D8;
    --ck-primary-d: #0096b7;
    --ck-dark:      #1a1a2e;
    --ck-cream:     #f8f5f0;
    --ck-white:     #ffffff;
    --ck-text:      #2d2d2d;
    --ck-muted:     #6b7280;
    --ck-success:   #22c55e;
    --ck-danger:    #ef4444;
    --ck-shadow:    0 8px 32px rgba(0,0,0,0.09);
    --ck-radius:    16px;
    --ck-font:      'Inter', sans-serif;
    --ck-serif:     'Playfair Display', serif;
}

.ck-page {
    background: var(--ck-cream);
    min-height: 80vh;
    padding: 0 0 60px;
    font-family: var(--ck-font);
    color: var(--ck-text);
}

/* ── PROGRESS STEPS ── */
.ck-steps {
    background: linear-gradient(135deg, var(--ck-dark), #16213e);
    padding: 28px 24px;
}
.ck-steps__inner {
    max-width: 500px; margin: 0 auto;
    display: flex; align-items: center; justify-content: center;
}
.ck-step {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    color: rgba(255,255,255,.4);
    font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .5px;
    transition: color .3s;
}
.ck-step.done { color: var(--ck-success); }
.ck-step.active { color: var(--ck-primary); }
.ck-step__dot {
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 2px solid currentColor;
    display: flex; align-items: center; justify-content: center;
    font-size: .9rem;
    background: rgba(255,255,255,.06);
}
.ck-step.done .ck-step__dot { background: rgba(34,197,94,.15); }
.ck-step.active .ck-step__dot { background: rgba(0,180,216,.18); }
.ck-steps__line {
    flex: 1; height: 2px; max-width: 60px;
    background: rgba(255,255,255,.15);
    margin: 0 8px; margin-bottom: 22px;
    transition: background .3s;
}
.ck-steps__line.done { background: var(--ck-success); }

/* ── ALERTS ── */
.ck-alert {
    max-width: 900px; margin: 20px auto 0; padding: 14px 20px;
    border-radius: 10px; font-size: .9rem;
    display: flex; align-items: center; gap: 10px;
}
.ck-alert--success { background: #f0fdf4; border: 1px solid #86efac; color: #15803d; }
.ck-alert--error   { background: #fef2f2; border: 1px solid #fca5a5; color: #dc2626; }
.ck-alert--info    { background: #eff6ff; border: 1px solid #93c5fd; color: #1d4ed8; }

/* ── EMPTY ── */
.ck-empty { text-align: center; padding: 80px 20px; }
.ck-empty i { font-size: 3rem; color: var(--ck-muted); margin-bottom: 16px; display: block; }
.ck-empty p { color: var(--ck-muted); margin-bottom: 20px; }

/* ── LAYOUT ── */
.ck-layout {
    max-width: 1100px; margin: 36px auto 0; padding: 0 24px;
    display: grid; grid-template-columns: 1fr 420px; gap: 28px;
    align-items: start;
}
@@media (max-width: 860px) {
    .ck-layout { grid-template-columns: 1fr; }
    .ck-payment-col { order: -1; }
}

/* ── PANEL ── */
.ck-panel {
    background: var(--ck-white);
    border-radius: var(--ck-radius);
    box-shadow: var(--ck-shadow);
    overflow: hidden;
}
.ck-panel__head {
    padding: 18px 24px;
    background: linear-gradient(135deg, var(--ck-dark), #16213e);
}
.ck-panel__head h2 {
    margin: 0; font-family: var(--ck-serif);
    font-size: 1.15rem; color: #fff; font-weight: 700;
    display: flex; align-items: center; gap: 10px;
}
.ck-panel__head h2 i { color: var(--ck-primary); }
.ck-panel__body { padding: 24px; }

/* ── ORDER ITEMS ── */
.ck-order-item {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid #f3f4f6;
}
.ck-order-item:last-of-type { border-bottom: none; }
.ck-order-item__cover {
    width: 60px; height: 85px; border-radius: 6px; overflow: hidden; flex-shrink: 0;
}
.ck-order-item__cover img { width: 100%; height: 100%; object-fit: cover; }
.ck-order-item__cover-ph {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #dbeafe, #bfdbfe);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; color: var(--ck-primary);
}
.ck-order-item__info { flex: 1; min-width: 0; }
.ck-order-item__title {
    font-weight: 700; font-size: .9rem; margin: 0 0 2px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.ck-order-item__meta { font-size: .78rem; color: var(--ck-muted); margin: 0 0 8px; }
.ck-order-item__tags { display: flex; gap: 6px; flex-wrap: wrap; }
.ck-order-item__price { font-size: 1rem; font-weight: 700; color: var(--ck-dark); flex-shrink: 0; direction: ltr; unicode-bidi: bidi-override; }

/* Tags */
.ck-tag {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 9px; border-radius: 20px;
    font-size: .73rem; font-weight: 600;
}
.ck-tag--borrow { background: #eff6ff; color: #2563eb; }
.ck-tag--buy    { background: #f0fdf4; color: #16a34a; }
.ck-tag--qty    { background: #f3f4f6; color: var(--ck-muted); }

/* Summary Totals */
.ck-summary-total { margin-top: 20px; padding-top: 14px; border-top: 2px solid var(--ck-cream); }
.ck-summary-total__row {
    display: flex; justify-content: space-between;
    font-size: .9rem; margin-bottom: 8px; color: var(--ck-muted);
}
.ck-summary-total__row span:last-child { color: var(--ck-text); font-weight: 600; }
.ck-summary-total__row--grand {
    font-size: 1.1rem; font-weight: 700; color: var(--ck-dark); margin-top: 8px;
}
.ck-summary-total__row--grand span:last-child { color: var(--ck-primary); font-size: 1.25rem; direction: ltr; unicode-bidi: bidi-override; }
.ck-summary-total__divider { height: 1px; background: var(--ck-cream); margin: 8px 0; }
.ck-free { color: var(--ck-success) !important; }

/* ── PAYMENT OPTIONS ── */
.ck-payment-intro { font-size: .88rem; color: var(--ck-muted); margin: 0 0 18px; text-align: center; }

.ck-pay-option {
    width: 100%;
    display: flex; align-items: center; gap: 14px;
    padding: 16px 18px;
    background: var(--ck-white);
    border: 2px solid #e5e7eb;
    border-radius: 12px; cursor: pointer;
    transition: border-color .2s, box-shadow .2s;
    text-align: left;
    margin-bottom: 4px;
}
.ck-pay-option:hover {
    border-color: var(--ck-primary);
    box-shadow: 0 0 0 4px rgba(0,180,216,.1);
}
.ck-pay-option__icon {
    width: 44px; height: 44px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
}
.ck-pay-option__icon--card { background: linear-gradient(135deg, #1a1a2e, #16213e); color: var(--ck-primary); }
.ck-pay-option__info { flex: 1; }
.ck-pay-option__info strong { display: block; font-size: .95rem; color: var(--ck-dark); }
.ck-pay-option__info span { font-size: .78rem; color: var(--ck-muted); }
.ck-pay-option__arrow { color: var(--ck-muted); font-size: .8rem; }

.ck-pay-or {
    text-align: center; position: relative; margin: 14px 0;
    font-size: .8rem; color: var(--ck-muted);
}
.ck-pay-or::before, .ck-pay-or::after {
    content: ''; position: absolute; top: 50%; width: 42%;
    height: 1px; background: #e5e7eb;
}
.ck-pay-or::before { left: 0; }
.ck-pay-or::after  { right: 0; }
.ck-pay-or span { position: relative; background: var(--ck-white); padding: 0 8px; }

.ck-paypal-wrap {
    border: 2px solid #e5e7eb; border-radius: 12px; overflow: hidden;
    transition: border-color .2s;
}
.ck-paypal-wrap:hover { border-color: #ffd140; }
.ck-paypal-label {
    background: #ffd140;
    color: #1a1a1a;
    text-align: center;
    padding: 6px 10px;
    font-size: .78rem; font-weight: 700;
    display: flex; align-items: center; justify-content: center; gap: 6px;
}
.ck-paypal-label i { font-size: .95rem; }
#paypal-button-container { padding: 8px; background: #fff; }

.ck-back-link { margin-top: 20px; text-align: center; }

/* ── BUTTONS ── */
.ck-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px; border-radius: 10px;
    font-family: var(--ck-font); font-size: .9rem; font-weight: 600;
    text-decoration: none; cursor: pointer; border: none;
    transition: all .2s;
}
.ck-btn--primary {
    background: var(--ck-primary); color: #fff;
    box-shadow: 0 4px 14px rgba(0,180,216,.35);
}
.ck-btn--primary:hover {
    background: var(--ck-primary-d); color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(0,180,216,.45);
    text-decoration: none;
}
.ck-btn--ghost {
    background: transparent; color: var(--ck-muted);
    border: 1.5px solid #e5e7eb;
}
.ck-btn--ghost:hover { background: #f9fafb; color: var(--ck-dark); text-decoration: none; }

/* ── CREDIT CARD MODAL ── */
.ck-modal-overlay {
    position: fixed; inset: 0; z-index: 2000;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none; opacity: 0;
    transition: opacity .25s;
}
.ck-modal-overlay.open { pointer-events: auto; opacity: 1; }
.ck-modal-backdrop {
    position: fixed; inset: 0; z-index: 1999;
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(4px);
    opacity: 0; pointer-events: none;
    transition: opacity .25s;
}
.ck-modal-overlay.open ~ .ck-modal-backdrop { opacity: 1; pointer-events: auto; }

.ck-modal {
    background: var(--ck-white);
    border-radius: 20px;
    padding: 32px 28px;
    width: 100%; max-width: 420px;
    box-shadow: 0 24px 80px rgba(0,0,0,.25);
    position: relative; z-index: 2001;
    transform: translateY(20px) scale(.97);
    transition: transform .25s;
}
.ck-modal-overlay.open .ck-modal { transform: translateY(0) scale(1); }

/* Card Preview */
.ck-card-preview {
    background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 50%, #16213e 100%);
    border-radius: 14px; padding: 22px; margin-bottom: 24px;
    min-height: 140px; position: relative; overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,.3);
}
.ck-card-preview::before {
    content: '';
    position: absolute; top: -30px; right: -30px;
    width: 140px; height: 140px;
    background: rgba(0,180,216,.15);
    border-radius: 50%;
}
.ck-card-preview__chip {
    width: 36px; height: 28px;
    background: linear-gradient(135deg, #f0a500, #ffd140);
    border-radius: 5px;
    display: flex; align-items: center; justify-content: center;
    font-size: .7rem; color: #1a1a1a;
    margin-bottom: 18px;
}
.ck-card-preview__number {
    font-size: 1.15rem; letter-spacing: .15em;
    color: #fff; font-weight: 600; margin-bottom: 14px;
    font-family: monospace;
}
.ck-card-preview__bottom { display: flex; gap: 32px; }
.ck-card-preview__label { font-size: .6rem; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: .1em; margin-bottom: 2px; }
.ck-card-preview__value { font-size: .82rem; color: #fff; font-weight: 600; }

/* Modal form */
.ck-modal__title {
    font-family: var(--ck-serif); font-size: 1.2rem; font-weight: 700;
    color: var(--ck-dark); margin: 0 0 20px; text-align: center;
}
.ck-form-group { margin-bottom: 16px; }
.ck-form-group label { display: block; font-size: .78rem; font-weight: 600; color: var(--ck-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .05em; }
.ck-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.ck-input-wrap { position: relative; }
.ck-input-wrap i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--ck-muted); font-size: .85rem; pointer-events: none; }
.ck-input {
    width: 100%; padding: 11px 12px 11px 36px;
    border: 1.5px solid #e5e7eb; border-radius: 9px;
    font-size: .92rem; font-family: var(--ck-font); color: var(--ck-dark);
    background: #fafafa; transition: border-color .2s, box-shadow .2s;
    box-sizing: border-box;
}
.ck-input:focus { outline: none; border-color: var(--ck-primary); box-shadow: 0 0 0 3px rgba(0,180,216,.12); background: #fff; }
.ck-modal__actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 22px; }
</style>

<script>
// Format card number input with spaces
function formatCardNumber(input) {
    let val = input.value.replace(/\D/g, '').substring(0, 16);
    let formatted = val.replace(/(.{4})/g, '$1 ').trim();
    input.value = formatted;
    let display = val.padEnd(16, '•').replace(/(.{4})/g, '$1 ').trim();
    document.getElementById('preview-number').textContent = display;
}

// Format expiry date
function formatExpiry(input) {
    let val = input.value.replace(/\D/g, '').substring(0, 4);
    if (val.length >= 3) val = val.substring(0,2) + '/' + val.substring(2);
    input.value = val;
    document.getElementById('preview-expiry').textContent = val || 'MM/YY';
}

// SweetAlert2 helper
function showAlert(title, text, icon) {
    Swal.fire({ title, text, icon, confirmButtonText: 'OK',
        customClass: { confirmButton: 'ck-btn ck-btn--primary' },
        buttonsStyling: false
    });
}

// Confirm credit card payment
function confirmPayment() {
    const cardNumber = document.getElementById('cardNumber').value.replace(/\s/g,'').trim();
    const cardHolderName = document.getElementById('cardHolderName').value.trim();
    const expiryDate = document.getElementById('expiryDate').value.trim();
    const cvv = document.getElementById('cvv').value.trim();

    if (!cardNumber || cardNumber.length !== 16 || !/^\d{16}$/.test(cardNumber)) {
        showAlert('Invalid Card', 'Please enter a valid 16-digit card number.', 'error'); return;
    }
    if (!cardHolderName || !/^[a-zA-Z\s]+$/.test(cardHolderName)) {
        showAlert('Invalid Name', 'Please enter a valid cardholder name.', 'error'); return;
    }
    const [month, year] = expiryDate.split('/');
    const inputDate = new Date(`20${year}`, month - 1);
    if (!expiryDate || !/^(0[1-9]|1[0-2])\/\d{2}$/.test(expiryDate) || inputDate < new Date()) {
        showAlert('Invalid Date', 'Please enter a valid expiry date (MM/YY).', 'error'); return;
    }
    if (!cvv || cvv.length < 3 || cvv.length > 4 || isNaN(cvv)) {
        showAlert('Invalid CVV', 'Please enter a valid 3–4 digit CVV.', 'error'); return;
    }

    document.getElementById('ck-cc-modal').classList.remove('open');
    processPayment('creditCard');
}

function processPayment(method) {
    Swal.fire({
        title: 'Processing Payment…',
        html: 'Please wait a moment.',
        icon: 'info',
        showConfirmButton: false,
        allowOutsideClick: false,
        didOpen: () => Swal.showLoading()
    });

    $.post('/Payment/ProcessPayment', { paymentMethod: method })
        .done(function (res) {
            Swal.close();
            if (res.success) {
                Swal.fire({
                    title: 'Payment Successful!',
                    text: 'Thank you for your purchase!',
                    icon: 'success', confirmButtonText: 'Continue',
                    customClass: { confirmButton: 'ck-btn ck-btn--primary' },
                    buttonsStyling: false
                }).then(() => window.location.href = res.redirectUrl);
            } else {
                showAlert('Payment Failed', res.message || 'An error occurred.', 'error');
            }
        })
        .fail(() => { Swal.close(); showAlert('Error', 'A server error occurred.', 'error'); });
}

function cancelPayment() {
    document.getElementById('ck-cc-modal').classList.remove('open');
}

// PayPal
paypal.Buttons({
    createOrder: function (data, actions) {
        return actions.order.create({
            purchase_units: [{ amount: { value: '@ViewBag.TotalAmount', currency_code: 'ILS' } }]
        });
    },
    onApprove: function (data, actions) {
        Swal.fire({ title: 'Processing Payment…', html: 'Please wait.', icon: 'info',
            showConfirmButton: false, allowOutsideClick: false, didOpen: () => Swal.showLoading() });

        return actions.order.capture().then(function (orderData) {
            return fetch('/Payment/ProcessPayment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                body: JSON.stringify({ paymentMethod: 'paypal', orderID: orderData.id })
            })
            .then(r => r.json())
            .then(d => {
                Swal.close();
                if (d.success) {
                    Swal.fire({ title: 'Payment Successful!', text: 'Enjoy your books!', icon: 'success',
                        confirmButtonText: 'Continue',
                        customClass: { confirmButton: 'ck-btn ck-btn--primary' }, buttonsStyling: false
                    }).then(() => window.location.href = d.redirectUrl);
                } else {
                    showAlert('Payment Failed', d.message || 'An error occurred.', 'error');
                }
            })
            .catch(() => { Swal.close(); showAlert('Error', 'Server error.', 'error'); });
        });
    },
    onError: function (err) {
        showAlert('PayPal Error', 'There was an error with PayPal. Please try again.', 'error');
        console.error('PayPal Error:', err);
    }
}).render('#paypal-button-container');
</script>
