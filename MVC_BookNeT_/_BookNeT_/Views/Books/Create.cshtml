@model _BookNeT_.Models.Books

<div class="container mt-0 d-flex justify-content-center"> <!-- הסרת רווח למעלה -->
    <div class="shadow p-4 rounded" style="background-color: #f3f2ec; max-width: 800px; width: 100%;">
        <h2 class="text-center mb-4" style="color: black;">Add a New Book</h2>

        <form method="post" action="/Books/Create">
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            
            <!-- Book's Name -->
            <div class="mb-3">
                <label class="form-label">Book's Name *</label>
                <input type="text" name="Title" class="form-control" required minlength="1" maxlength="100" placeholder="Enter the book's name"/>
            </div>

            <!-- Author's Name -->
            <div class="mb-3">
                <label class="form-label">Author's Name *</label>
                <input type="text" name="Author" class="form-control" required minlength="1" maxlength="100" placeholder="Enter the author's name"/>
            </div>

            <!-- Publisher -->
            <div class="mb-3">
                <label class="form-label">Publisher *</label>
                <input type="text" name="Publisher" class="form-control" required placeholder="Enter publisher's name"/>
            </div>

            <!-- Year of Publication -->
            <div class="mb-3">
                <label class="form-label">Year Of Publication</label>
                <input type="number" name="YearOfPublication" class="form-control" min="1900" max="2024" placeholder="Enter year"/>
            </div>

            <!-- Image URL -->
            <div class="mb-3">
                <label class="form-label">Image URL</label>
                <input type="url" name="ImageUrl" class="form-control" placeholder="Enter image URL"/>
            </div>

            <!-- Formats -->
            <div class="mb-3">
                <label class="form-label">Formats *</label>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SelectedFormats" value="PDF" id="formatPDF"/>
                    <label class="form-check-label" for="formatPDF">PDF</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SelectedFormats" value="MOBI" id="formatMOBI"/>
                    <label class="form-check-label" for="formatMOBI">MOBI</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SelectedFormats" value="EPUB" id="formatEPUB"/>
                    <label class="form-check-label" for="formatEPUB">EPUB</label>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SelectedFormats" value="F2B" id="formatF2B"/>
                    <label class="form-check-label" for="formatF2B">F2B</label>
                </div>

            </div>

            <!-- Genre -->
            <div class="mb-3">
                <label class="form-label">Genre *</label>
                <select name="Genre" class="form-select" required>
                    <option value="">Select Genre</option>
                    <option value="Fiction">Fiction</option>
                    <option value="Non-Fiction">Non-Fiction</option>
                    <option value="Science Fiction">Science Fiction</option>
                    <option value="Fantasy">Fantasy</option>
                    <option value="Mystery">Mystery</option>
                    <option value="Biography">Biography</option>
                    <option value="History">History</option>
                    <option value="Self-Help">Self-Help</option>
                </select>
            </div>

            <!-- Age Category -->
            <div class="mb-3">
                <label class="form-label">Age Category</label>
                <select name="AgeRestriction" class="form-select">
                    <option value="">All Ages</option>
                    <option value="0">All Ages</option>
                    <option value="3">Toddlers (0-3)</option>
                    <option value="5">Preschool (4-5)</option>
                    <option value="7">Early Readers (6-7)</option>
                    <option value="12">Children (8-12)</option>
                    <option value="14">Young Teen (12-14)</option>
                    <option value="17">Teen & Young Adult (13-17)</option>
                    <option value="18">Adult (18+)</option>
                </select>
            </div>

            <!-- Purchase Price -->
            <div class="mb-3">
                <label class="form-label">Purchase Price *</label>
                <input type="number" name="PurchasePrice" class="form-control" required min="0" step="0.01" placeholder="Enter purchase price"/>
            </div>

            <!-- Borrow Price -->
            <div class="mb-3">
                <label class="form-label">Borrow Price</label>
                <input type="number" name="BorrowPrice" class="form-control" min="0" step="0.01" placeholder="Enter borrow price"/>
            </div>

            <!-- Number of Copies -->
            <div class="mb-3">
                <label class="form-label">Number of Copies *</label>
                <input type="number" name="Stock" class="form-control" required min="0" placeholder="Enter stock"/>
            </div>

            <!-- Is Borrowable -->
            <div class="mb-3">
                <label class="form-label">Is Borrowable *</label>
                <select name="IsBorrowable" class="form-select" required>
                    <option value="">Select</option>
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>

            <!-- Is Discounted -->
            <div class="mb-3">
                <label class="form-label">Is Discounted *</label>
                <select name="IsDiscounted" class="form-select" required>
                    <option value="">Select</option>
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>

            <!-- Discount Percentage -->
            <div class="mb-3">
                <label class="form-label">Discount Percentage</label>
                <input type="number" name="DiscountPercentage" class="form-control" min="0" max="100" step="0.01" placeholder="Enter discount percentage"/>
            </div>

            <div class="mb-3">
                <label class="form-label">Discount End Date</label>
                <input type="date" name="DiscountEndDate" class="form-control"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                       max="@DateTime.Today.AddDays(7).ToString("yyyy-MM-dd")"
                       placeholder="Select a date" />
            </div>

            <div class="form-group">
                <label>Status *</label>
                <select id="statusField" name="Status" class="form-control" required>
                    <option value="Available" selected>Available</option>
                    <option value="Out of Stock">Out of Stock</option>
                    <option value="Coming Soon">Coming Soon</option>
                </select>
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="Description" class="form-control" placeholder="Enter book description"></textarea>
            </div>

            <!-- Buttons -->
            <div class="text-center mt-4">
                <button type="submit" class="btn btn-primary px-4">Save</button>
                <a href="/Books/Index" class="btn btn-secondary px-4">Back to List</a>
            </div>
        </form>
    </div>
</div>

<style>
    /* ביטול רווחים גלובליים */
    body {
        margin: 0;
        padding: 0;
        background-color: #f3f2ec; /* רקע כללי בז' */
    }

    /* ביטול רווח מיותר אחרי ה-NAVBAR */
    .container-fluid, .container {
        margin-top: 0 !important;
    }

    /* עיצוב טופס */
    .form-control, .form-select, textarea {
        background-color: #f3f2ec; /* רקע בז' */
        color: black; /* טקסט שחור */
        border: 1px solid #ccc; /* גבול אפור בהיר */
        z-index: 1000;
    }

    .form-control::placeholder, textarea::placeholder {
        color: #aaa;
    }

    /* עיצוב כללי לטקסט */
    h2, h3, h4, h5, h6 {
        color: black; /* טקסט שחור */
        margin-top: 0;
    }

    /* כפתורים */
    .btn {
        background-color: #f3f2ec; /* רקע בז' */
        color: black; /* טקסט שחור */
        border: 1px solid black; /* גבול שחור */
    }

    .btn:hover {
        background-color: #ddd; /* רקע אפור בהיר בעת מעבר עכבר */
        color: black;
    }

    /* קונטיינרים */
    .container, .shadow {
        background-color: #f3f2ec; /* רקע בז' */
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    .custom-bg {
        background-color: #f3f2ec; /* צבע בז' */
    }
</style>


<script>
    function updateStatus() {
        const stockValue = parseInt(document.querySelector('input[name="Stock"]').value);
        const statusField = document.getElementById('statusField');

        // מעדכן את האפשרויות הזמינות
        const availableOption = statusField.querySelector('option[value="Available"]');
        const outOfStockOption = statusField.querySelector('option[value="Out of Stock"]');
        const comingSoonOption = statusField.querySelector('option[value="Coming Soon"]');

        if (stockValue === 0) {
            availableOption.disabled = true;  // חוסם Available כשאין מלאי
            outOfStockOption.disabled = false;
            comingSoonOption.disabled = false;   // מאפשר Coming Soon רק כשאין עותקים
            if (statusField.value === "Available") {
                statusField.value = "Out of Stock";
            }
        } else {
            availableOption.disabled = false;
            outOfStockOption.disabled = true;   // חוסם Out of Stock כשיש מלאי
            comingSoonOption.disabled = true;   // חוסם Coming Soon כשיש עותקים
            if (statusField.value === "Out of Stock" || statusField.value === "Coming Soon") {
                statusField.value = "Available";
            }
        }
    }

    // מאזינים לשינויים
    document.querySelector('input[name="Stock"]').addEventListener('change', updateStatus);
    document.querySelector('select[name="IsBorrowable"]').addEventListener('change', updateStatus);

    // הפעלה ראשונית של הבדיקה
    updateStatus();

    // להוסיף לסקריפט הקיים
    function setMaxDiscountDate() {
        const discountDateField = document.querySelector('input[name="DiscountEndDate"]');
        const today = new Date();
        const maxDate = new Date(today);
        maxDate.setDate(today.getDate() + 7); // מקסימום שבוע קדימה

        // מגדיר את התאריך המינימלי להיום
        discountDateField.min = today.toISOString().split('T')[0];
        // מגדיר את התאריך המקסימלי לשבוע מהיום
        discountDateField.max = maxDate.toISOString().split('T')[0];
    }

    function validateDiscountDate() {
        const isDiscounted = document.querySelector('select[name="IsDiscounted"]').value === "true";
        const discountDateField = document.querySelector('input[name="DiscountEndDate"]');
        const discountPercentageField = document.querySelector('input[name="DiscountPercentage"]');

        if (isDiscounted) {
            if (!discountDateField.value) {
                const today = new Date();
                const maxDate = new Date(today);
                maxDate.setDate(today.getDate() + 7);
                discountDateField.value = maxDate.toISOString().split('T')[0];
            }
            discountDateField.required = true;
            discountPercentageField.required = true;
        } else {
            discountDateField.required = false;
            discountPercentageField.required = false;
            discountDateField.value = '';
            discountPercentageField.value = '';
        }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        setMaxDiscountDate();
        validateDiscountDate();
        validatePrices();
        
        document.querySelector('select[name="IsDiscounted"]').addEventListener('change', function() {
            validateDiscountDate();
            toggleDiscountPercentage();
        });
    });
    function validateDiscountFields() {
        const isDiscounted = document.querySelector('select[name="IsDiscounted"]').value === "true";
        const discountEndDateField = document.querySelector('input[name="DiscountEndDate"]');
        const discountPercentageField = document.querySelector('input[name="DiscountPercentage"]');
        const today = new Date();
        const maxDate = new Date(today);
        maxDate.setDate(today.getDate() + 7);

        // Reset any previous error messages
        discountEndDateField.setCustomValidity('');
        discountPercentageField.setCustomValidity('');

        if (isDiscounted) {
            // Validate Discount End Date
            const discountDateValue = new Date(discountEndDateField.value);
            if (!discountEndDateField.value || discountDateValue < today || discountDateValue > maxDate) {
                discountEndDateField.setCustomValidity('Discount end date must be between today and 7 days from now.');
            }

            // Validate Discount Percentage
            const discountPercentageValue = parseFloat(discountPercentageField.value);
            if (!discountPercentageField.value || discountPercentageValue <= 0 || discountPercentageValue > 100) {
                discountPercentageField.setCustomValidity('Please enter a valid discount percentage (1-100).');
            }
        } else {
            // Clear values if not discounted
            discountEndDateField.value = '';
            discountPercentageField.value = '';
        }
    }

    // Event listeners for dynamic validation
    document.querySelector('select[name="IsDiscounted"]').addEventListener('change', validateDiscountFields);
    document.querySelector('input[name="DiscountEndDate"]').addEventListener('input', validateDiscountFields);
    document.querySelector('input[name="DiscountPercentage"]').addEventListener('input', validateDiscountFields);

    // Initial call to setup validation
    document.addEventListener('DOMContentLoaded', validateDiscountFields);

    function validatePrices() {
        const purchasePriceField = document.querySelector('input[name="PurchasePrice"]');
        const borrowPriceField = document.querySelector('input[name="BorrowPrice"]');
        const form = document.querySelector('form');

        form.addEventListener('submit', function(event) {
            const purchasePrice = parseFloat(purchasePriceField.value) || 0;
            const borrowPrice = parseFloat(borrowPriceField.value) || 0;

            if (borrowPrice > purchasePrice && borrowPrice > 0) {
                event.preventDefault();
                alert('Error: Borrow price cannot be higher than the purchase price');
                return false;
            }

            if (purchasePrice < borrowPrice && borrowPrice > 0) {
                event.preventDefault();
                alert('Error: Purchase price cannot be lower than Borrow price');
                return false;
            }
        });
    }
    
</script>