@model IEnumerable<_BookNeT_.Models.Books>

<div class="container mt-5" style="background-color: #f3f2ec; padding: 20px; border-radius: 10px;">
    <h2 class="text-center mb-4" style="color: black;">Book List</h2>

    <!-- Bulk Discount Section -->
    <div class="mb-4 p-3 border rounded">
        <h4 class="mb-3">Global Discount Management</h4>
        <div class="row g-3">
            <!-- Apply Discount Form -->
            <div class="col-12">
                <form method="post" action="/Books/ApplyBulkDiscount" class="row g-3">
                    @Html.AntiForgeryToken()

                    <div class="col-md-3">
                        <select name="Genre" class="form-select genre-select">
                            <option value="">All Genres</option>
                            <option value="Fiction">Fiction</option>
                            <option value="Non-Fiction">Non-Fiction</option>
                            <option value="Science Fiction">Science Fiction</option>
                            <option value="Fantasy">Fantasy</option>
                            <option value="Mystery">Mystery</option>
                            <option value="Biography">Biography</option>
                            <option value="History">History</option>
                            <option value="Self-Help">Self-Help</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <input type="number" name="DiscountPercentage" class="form-control"
                               placeholder="Discount %" required min="1" max="100" step="0.01"/>
                    </div>

                    <div class="col-md-3">
                        <input type="date" name="DiscountEndDate" class="form-control" required
                               min="@DateTime.Today.ToString("yyyy-MM-dd")"
                               max="@DateTime.Today.AddDays(7).ToString("yyyy-MM-dd")"/>
                    </div>

                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">Apply Bulk Discount</button>
                    </div>
                </form>
            </div>

            <!-- Cancel Discount Form -->
            <div class="col-12">
                <form method="post" action="/Books/CancelBulkDiscount" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-3">
                        <select name="Genre" class="form-select genre-select">
                            <option value="">All Genres</option>
                            <option value="Fiction">Fiction</option>
                            <option value="Non-Fiction">Non-Fiction</option>
                            <option value="Science Fiction">Science Fiction</option>
                            <option value="Fantasy">Fantasy</option>
                            <option value="Mystery">Mystery</option>
                            <option value="Biography">Biography</option>
                            <option value="History">History</option>
                            <option value="Self-Help">Self-Help</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-danger w-100">Cancel Discounts</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="text-start mb-3">
        <a href="/Books/Create" class="btn btn-success"><i class="fas fa-plus"></i> Add New Book</a>
    </div>
    <div class="table-responsive shadow rounded" style="background-color: #f3f2ec;">
        <table class="table table-bordered table-hover text-center align-middle" style="background-color: #f3f2ec;">
            <thead class="table-dark" style="background-color: #333333;">
            <tr>
                <th style="width: 120px; color: black;">Image</th>
                <th style="color: black;">Title</th>
                <th style="color: black;">Author</th>
                <th style="color: black;">Publisher</th>
                <th style="color: black;">Year</th>
                <th style="color: black;">Genre</th>
                <th style="color: black;">Copies</th>
                <th style="width: 200px; color: black;">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var book in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" alt="@book.Title" class="img-thumbnail" style="max-width: 100px; height: auto;" />
                        }
                        else
                        {
                            <span class="text-muted">No Image</span>
                        }
                    </td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.Publisher</td>
                    <td>@book.YearOfPublication</td>
                    <td>@book.Genre</td>
                    <td>@book.Stock</td>
                    <td>
                        <div class="d-flex justify-content-evenly">
                            <a href="/Books/Details/@book.BookID" class="btn btn-info btn-sm">
                                <i class="fas fa-eye"></i> Details
                            </a>
                            <a href="/Books/Edit/@book.BookID" class="btn btn-warning btn-sm">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <a href="/Books/Delete/@book.BookID" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this book?')">
                                <i class="fas fa-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<style>
    body {
        background-color: #f3f2ec; /* צבע קרם */
    }

    h2 {
        color: black; /* צבע לכותרת Book List */
    }

    .table thead th {
        background-color: #f3f2ec; /* צבע קרם לכותרות הטבלה */
        color: black; /* טקסט שחור בכותרות */
    }

    .table tbody td {
        background-color: #f3f2ec; /* צבע קרם לתאי הטבלה */
    }

    .btn {
        background-color: #f3f2ec; /* צבע קרם לכפתורים */
        color: black; /* טקסט שחור לכפתורים */
        border: 1px solid black; /* גבול שחור לכפתורים */
    }

    .btn:hover {
        background-color: #ddd; /* צבע רקע אפור בהיר בעת מעבר עכבר */
        color: black; /* שמירה על טקסט שחור */
    }

    .form-select,
    .form-control {
        background-color: #f3f2ec;
        color: black;
        border: 1px solid black;
        padding: 8px;
        border-radius: 4px;
    }

    .form-select:hover,
    .form-control:hover {
        background-color: #ddd;
    }

    .form-select:focus,
    .form-control:focus {
        box-shadow: none;
        border-color: black;
        background-color: #f3f2ec;
    }

    .form-control::placeholder {
        color: #666;
    }

    input[type="date"].form-control {
        padding: 6px 8px;
    }

    input[type="number"].form-control {
        padding-right: 4px;
    }
    
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const bulkDiscountForm = document.querySelector('form[action="/Books/ApplyBulkDiscount"]');
        const bulkDiscountDateField = bulkDiscountForm.querySelector('input[name="DiscountEndDate"]');
        const genreSelect = document.querySelector('select[name="Genre"]');
        const genreInput = document.querySelector('.genre-input');

        function setBulkDiscountDateLimits() {
            const today = new Date();
            const maxDate = new Date(today);
            maxDate.setDate(today.getDate() + 7);

            bulkDiscountDateField.min = today.toISOString().split('T')[0];
            bulkDiscountDateField.max = maxDate.toISOString().split('T')[0];

            if (!bulkDiscountDateField.value) {
                bulkDiscountDateField.value = maxDate.toISOString().split('T')[0];
            }
        }

        bulkDiscountForm.addEventListener('submit', function(event) {
            const discountDate = new Date(bulkDiscountDateField.value);
            const today = new Date();
            const maxDate = new Date(today);
            maxDate.setDate(today.getDate() + 7);

            if (discountDate < today || discountDate > maxDate) {
                event.preventDefault();
                alert('Discount end date must be between today and 7 days from now');
                return false;
            }
        });

        genreSelect.addEventListener('change', () => {
            genreInput.value = genreSelect.value;
        });

        setBulkDiscountDateLimits();
    });
    
</script>

