@model List<_BookNeT_.Models.BookUser.UserBookHistoryViewModel>

@{
    ViewBag.Title = "Your Book History";
    Layout = "~/Views/Shared/_Tools.cshtml";
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Loading Bootstrap files -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/js/bootstrap.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <script src="~/Js/cart.js"></script>

</head>
@if (Session["Email"] != null)
{
    <div class="cart-icon">
        <a href="@Url.Action("Index", "ShoppingCart")" class="cart-link">
            <i class="fas fa-shopping-cart"></i>
            <span class="cart-count">@ViewBag.CartCount</span>
        </a>
    </div>
}

<div class="favorite-container">
    <div class="favorite-hero" style="background: linear-gradient(135deg, #2b2d42 0%, #8d99ae 100%);">
        <h1 class="favorite-title">Your Book History <i class="fas fa-history text-light"></i></h1>
        <p class="favorite-subtitle">A record of all your past activities and interactions.</p>
    </div>

    <div class="favorite-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var book in Model)
            {
                <div class="favorite-card">
                    <div class="card-image-wrap">
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" alt="@book.Title" class="book-cover" />
                        }
                        else
                        {
                            <div class="no-image-cover">
                                <i class="bi bi-journal-bookmark h1"></i>
                            </div>
                        }
                        
                        <!-- Floating badge showing Interaction Type -->
                        <div style="position: absolute; top: 1rem; right: 1rem; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); color: #fff; padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase;">
                            @book.InteractionType
                        </div>
                    </div>

                    <div class="card-content">
                        <h3>@book.Title</h3>
                        <p class="author">By: @book.Author</p>
                        <hr class="card-divider" />
                        <div class="card-meta mt-auto">
                            @if (book.PurchaseDate != null)
                            {
                                <small class="text-muted"><i class="bi bi-bag-check"></i> Date: @(Convert.ToDateTime(book.PurchaseDate).ToString("dd/MM/yyyy"))</small>
                            }
                            else if (book.BorrowDate != null)
                            {
                                <small class="text-muted"><i class="bi bi-book"></i> Date: @(Convert.ToDateTime(book.BorrowDate).ToString("dd/MM/yyyy"))</small>
                            }
                            else
                            {
                                <small class="text-muted"><i class="bi bi-question-circle"></i> Date: Not Available</small>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-clock-history empty-icon"></i>
                <h3>No history available</h3>
                <p>You haven't borrowed or purchased any books yet. Explore now!</p>
                <a href="@Url.Action("Index", "Library")" class="btn-explore">Explore Library</a>
            </div>
        }
    </div>
</div>

<style>
    /* =========================================================
       PREMIUM GRID DESIGN (Shared CSS Logic)
       ========================================================= */
    .favorite-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem;
    }

    .favorite-hero {
        border-radius: 20px;
        padding: 2.5rem 2rem;
        color: #fff;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        margin-bottom: 2rem;
    }

    .favorite-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .favorite-subtitle {
        color: rgba(255,255,255,0.8);
        font-size: 1rem;
        margin: 0;
    }

    .favorite-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 2rem;
    }

    .favorite-card {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .favorite-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    .card-image-wrap {
        position: relative;
        height: 320px;
        background: #f8f9fa;
        overflow: hidden;
    }

    .book-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .favorite-card:hover .book-cover {
        transform: scale(1.05);
    }

    .no-image-cover {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #e9ecef 0%, #f8f9fa 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #adb5bd;
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-content h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 0.3rem;
        line-height: 1.3;
    }

    .author {
        color: #6c757d;
        font-size: 0.9rem;
        margin: 0;
    }

    .card-divider {
        margin: 1rem 0;
        border-color: rgba(0,0,0,0.05);
    }

    .card-meta {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        font-size: 0.8rem;
    }

    /* Empty State */
    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 5rem 2rem;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
    }

    .empty-icon {
        font-size: 4rem;
        color: #dee2e6;
        margin-bottom: 1rem;
        display: block;
    }

    .empty-state h3 {
        font-family: 'Playfair Display', serif;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #6c757d;
        margin-bottom: 2rem;
    }

    .btn-explore {
        display: inline-block;
        background: #00B4D8;
        color: #fff;
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 180, 216, 0.3);
    }

    .btn-explore:hover {
        background: #0096b7;
        color: #fff;
        transform: translateY(-2px);
    }

    /* Cart FAB in Profile */
    .cart-link {
        position: fixed; bottom: 30px; right: 30px;
        background: #00B4D8; color: #fff;
        width: 56px; height: 56px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; margin: 0;
        box-shadow: 0 5px 20px rgba(0, 180, 216, 0.4);
        z-index: 1000;
    }
    .cart-count {
        position: absolute; top: -5px; right: -5px;
        background: #e63946; color: #fff; border-radius: 50%;
        width: 22px; height: 22px; font-size: 0.75rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
    }
</style>

