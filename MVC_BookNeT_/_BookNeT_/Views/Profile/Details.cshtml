@model _BookNeT_.Models.Users
@{
    ViewBag.Title = "פרטי משתמש";
    Layout = "~/Views/Shared/_Tools.cshtml";
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- הטעינה של קובצי Bootstrap -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/js/bootstrap.min.js"></script>
    <script src="~/Js/cart.js"></script>
    
</head>

@if (Session["Email"] != null)
{
    <a href="@Url.Action("Index", "ShoppingCart")" class="cart-link">
        <i class="fas fa-shopping-cart"></i>
        <span class="cart-count">@ViewBag.CartCount</span>
    </a>
}

<div>
    <!-- Premium Cover Area -->
    <div class="profile-hero">
        <div class="profile-avatar-wrap">
            <div class="profile-avatar">
                <i class="bi bi-person"></i>
            </div>
        </div>
        <h2 class="profile-name">@Model.FirstName @Model.LastName</h2>
        <span class="profile-role">@Model.Role</span>
    </div>

    <!-- Info Grid Cards -->
    <div class="profile-info-grid">
        <div class="info-card">
            <div class="info-item">
                <span class="info-label"><i class="bi bi-envelope"></i> Email Address</span>
                <p class="info-value" id="userEmail">@Model.Email</p>
            </div>
            <div class="info-item">
                <span class="info-label"><i class="bi bi-telephone"></i> Phone Number</span>
                <p class="info-value" id="userPhone">@(string.IsNullOrEmpty(Model.Phone) ? "Not Provided" : Model.Phone)</p>
            </div>
        </div>

        <div class="info-card">
            <div class="info-item">
                <span class="info-label"><i class="bi bi-calendar3"></i> Registration Date</span>
                <p class="info-value">@((Model.RegistrationDate != null) ? Model.RegistrationDate?.ToString("dd/MM/yyyy") : "N/A")</p>
            </div>
            <div class="info-item">
                <span class="info-label"><i class="bi bi-person-badge"></i> Age</span>
                <p class="info-value" id="userAge">@Model.Age</p>
            </div>
        </div>
    </div>

    <div class="text-center mt-3 mb-5">
        <button class="btn-edit-profile" id="editProfileBtn" data-bs-toggle="modal" data-bs-target="#editProfileModal">
            <i class="bi bi-pencil-square"></i> Edit Profile Details
        </button>
    </div>
</div>

<!-- Modal for Edit Profile -->
<div class="modal fade custom-modal" id="editProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-gear"></i> Profile Settings</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="editFirstName" class="form-label">First Name</label>
                        <input type="text" class="form-control" id="editFirstName" value="@Model.FirstName">
                    </div>
                    <div class="col-md-6">
                        <label for="editLastName" class="form-label">Last Name</label>
                        <input type="text" class="form-control" id="editLastName" value="@Model.LastName">
                    </div>
                    <div class="col-12">
                        <label for="editEmail" class="form-label">Email</label>
                        <input type="email" class="form-control" id="editEmail" value="@Model.Email">
                    </div>
                    <div class="col-md-6">
                        <label for="editPhone" class="form-label">Phone</label>
                        <input type="text" class="form-control" id="editPhone" maxlength="15" value="@Model.Phone" placeholder="Enter phone">
                    </div>
                    <div class="col-md-6">
                        <label for="editAge" class="form-label">Age</label>
                        <input type="number" class="form-control" id="editAge" value="@Model.Age">
                    </div>
                </div>

                <div class="divider"></div>

                <h6 class="mb-3" style="font-weight:700; color:#1a1a2e;">Change Password</h6>
                <div class="row g-3">
                    <div class="col-12">
                        <input type="password" class="form-control" id="newPassword" placeholder="New Password">
                    </div>
                    <div class="col-12">
                        <input type="password" class="form-control" id="confirmPassword" placeholder="Confirm New Password">
                    </div>
                    <div class="col-12 text-end">
                        <button type="button" class="btn-modal-password" id="ChangePassword">Update Password</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-modal-cancel" id="cancelEditBtn" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-modal-save" id="saveProfileBtn">Save Details</button>
            </div>
        </div>
    </div>
</div>


<style>
    /* =========================================================
       PREMIUM PROFILE DETAILS
       ========================================================= */
    .profile-hero {
        position: relative;
        background: linear-gradient(135deg, #00B4D8 0%, #0096b7 100%);
        border-radius: 24px;
        padding: 3rem 2rem 5rem;
        color: #fff;
        text-align: center;
        box-shadow: 0 15px 35px rgba(0, 180, 216, 0.2);
        margin-bottom: 2rem;
        overflow: hidden;
    }

    .profile-hero::before {
        content: '';
        position: absolute;
        top: -50%; left: -10%;
        width: 300px; height: 300px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        pointer-events: none;
    }

    .profile-avatar-wrap {
        position: relative;
        width: 120px;
        height: 120px;
        margin: 0 auto 1rem auto;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        background: #fff;
        color: #00B4D8;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        border: 4px solid rgba(255,255,255,0.8);
    }
    
    .profile-name {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        margin: 0 0 0.2rem;
    }
    .profile-role {
        background: rgba(255,255,255,0.2);
        padding: 0.3rem 1rem;
        border-radius: 50px;
        font-size: 0.85rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 600;
        backdrop-filter: blur(5px);
        display: inline-block;
    }

    /* Cards */
    .profile-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-top: -3rem; /* pull up over hero */
        position: relative;
        z-index: 10;
        padding: 0 1.5rem;
    }

    .info-card {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 8px 32px rgba(0,0,0,0.05);
        border: 1px solid rgba(255,255,255,0.8);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .info-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

    .info-item {
        margin-bottom: 1.5rem;
    }
    .info-item:last-child { margin-bottom: 0; }
    
    .info-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #888;
        font-weight: 700;
        margin-bottom: 0.3rem;
        display: block;
    }
    .info-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #1a1a2e;
        margin: 0;
    }

    .btn-edit-profile {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #1a1a2e;
        color: #fff;
        border: none;
        padding: 0.8rem 1.8rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        margin-top: 2rem;
        box-shadow: 0 4px 15px rgba(26,26,46,0.3);
    }
    .btn-edit-profile:hover {
        background: #2d2d4a;
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(26,26,46,0.4);
    }

    /* Modal Styling */
    .custom-modal .modal-content {
        border-radius: 24px;
        border: none;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    }
    .custom-modal .modal-header {
        background: #f8f9fa;
        border-bottom: 1px solid #eee;
        padding: 1.5rem 2rem;
    }
    .custom-modal .modal-title {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: #1a1a2e;
    }
    .custom-modal .modal-body {
        padding: 2rem;
    }
    .custom-modal .form-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #555;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .custom-modal .form-control {
        border-radius: 12px;
        padding: 0.8rem 1.2rem;
        border: 1px solid #ddd;
        background: #fcfcfc;
        transition: all 0.2s;
    }
    .custom-modal .form-control:focus {
        background: #fff;
        border-color: #00B4D8;
        box-shadow: 0 0 0 4px rgba(0, 180, 216, 0.1);
    }
    
    .divider {
        height: 1px;
        background: #eee;
        margin: 2rem 0;
    }

    .modal-footer {
        padding: 1.5rem 2rem;
        background: #fcfcfc;
        border-top: 1px solid #eee;
        gap: 0.5rem;
        justify-content: flex-end;
    }
    .btn-modal-cancel {
        color: #888;
        font-weight: 600;
        padding: 0.6rem 1.5rem;
    }
    .btn-modal-cancel:hover { color: #1a1a2e; }
    
    .btn-modal-password {
        background: #f0f0f0;
        color: #1a1a2e;
        border-radius: 50px;
        font-weight: 600;
        padding: 0.6rem 1.5rem;
        border: none;
    }
    .btn-modal-password:hover { background: #e0e0e0; }

    .btn-modal-save {
        background: #00B4D8;
        color: #fff;
        border-radius: 50px;
        font-weight: 600;
        padding: 0.6rem 1.8rem;
        border: none;
        box-shadow: 0 4px 15px rgba(0, 180, 216, 0.3);
    }
    .btn-modal-save:hover {
        background: #0096b7;
        color: #fff;
        transform: translateY(-1px);
    }

    /* Cart FAB in Profile */
    .cart-link {
        position: fixed; bottom: 30px; right: 30px;
        background: #00B4D8; color: #fff;
        width: 56px; height: 56px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; margin: 0;
        box-shadow: 0 5px 20px rgba(0, 180, 216, 0.4);
        z-index: 1000;
    }
    .cart-count {
        position: absolute; top: -5px; right: -5px;
        background: #e63946; color: #fff; border-radius: 50%;
        width: 22px; height: 22px; font-size: 0.75rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
    }
</style>



<script>

    $("#saveProfileBtn").click(function () {
        const originalFirstName = "@Model.FirstName";
        const originalLastName = "@Model.LastName";
        const originalEmail = "@Model.Email";
        const originalPhone = "@Model.Phone";
        const originalAge = "@Model.Age";

        const firstName = $("#editFirstName").val().trim();
        const lastName = $("#editLastName").val().trim();
        const email = $("#editEmail").val().trim();
        const phone = $("#editPhone").val().trim();
        const age = $("#editAge").val().trim();

        // בדיקה אם לא בוצעו שינויים
        if (
            firstName === originalFirstName &&
            lastName === originalLastName &&
            email === originalEmail &&
            phone === originalPhone &&
            age === originalAge
        ) {
            alert("No changes were made.");
            return;
        }

        if (!firstName || !lastName || !email || !phone || !age) {
            alert("All fields are required.");
            return;
        }

        $.ajax({
            url: '/Profile/SaveProfile',
            type: 'POST',
            data: {
                firstName: firstName,
                lastName: lastName,
                email: email,
                phone: phone,
                age: age
            },
            success: function (response) {
                if (response.success) {
                    alert(response.message);
                    $("#editProfileModal").modal("hide");
                    location.reload(); // רענן את העמוד כדי להציג את הנתונים המעודכנים
                } else {
                    alert(response.message || "Failed to save changes.");
                }
            },
            error: function () {
                alert("An error occurred. Please try again.");
            }
        });
    });


    $(document).ready(function () {
        $("#ChangePassword").click(function () {
            const newPassword = $("#newPassword").val().trim();
            const confirmPassword = $("#confirmPassword").val().trim();

            if (!newPassword || !confirmPassword) {
                alert("Both password fields are required.");
                return;
            }

            if (newPassword !== confirmPassword) {
                alert("Passwords do not match.");
                return;
            }

            if (newPassword.length < 6) {
                alert("Password must be at least 6 characters long.");
                return;
            }

            $.ajax({
                url: '/Profile/ChangePassword',
                type: 'POST',
                data: { newPassword: newPassword, confirmPassword: confirmPassword },
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        $("#newPassword").val('');
                        $("#confirmPassword").val('');
                    } else {
                        alert(response.message || "Failed to change password.");
                    }
                },
                error: function () {
                    alert("An error occurred. Please try again.");
                }
            });
        });


    // ביטול - סגירת המודל
        $("#cancelEditBtn").click(function () {
            $("#editProfileModal").modal("hide");
        });
    });

</script>