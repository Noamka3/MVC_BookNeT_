@model List<_BookNeT_.Models.BookUser.FavoriteBookViewModel>

@{
    ViewBag.Title = "Books You Loved";
    Layout = "~/Views/Shared/_Tools.cshtml";
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Bootstrap Files -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/js/bootstrap.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <script src="~/Js/cart.js"></script>

</head>

@if (Session["Email"] != null)
{
    <div class="cart-icon">
        <a href="@Url.Action("Index", "ShoppingCart")" class="cart-link">
            <i class="fas fa-shopping-cart"></i>
            <span class="cart-count">@ViewBag.CartCount</span>
        </a>
    </div>
}
<div class="favorite-container">
    <div class="favorite-hero">
        <h1 class="favorite-title">Books You Loved <i class="fas fa-heart text-danger"></i></h1>
        <p class="favorite-subtitle">Your personal collection of masterpieces.</p>
    </div>

    <div class="favorite-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var book in Model)
            {
                <div class="favorite-card">
                    <div class="card-image-wrap">
                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" alt="@book.Title" class="book-cover" />
                        }
                        else
                        {
                            <div class="no-image-cover">
                                <i class="bi bi-journal-bookmark h1"></i>
                            </div>
                        }
                        
                        <!-- Floating Remove Button visible immediately -->
                        <button class="btn-unlike" onclick="toggleFavorite(this)" data-book-id="@book.BookID" title="Remove from Favorites">
                            <i class="fas fa-heart-broken"></i> Unlike
                        </button>
                    </div>

                    <div class="card-content">
                        <h3>@book.Title</h3>
                        <p class="author">By: @book.Author</p>
                        <hr class="card-divider" />
                        <div class="card-meta">
                            <small class="text-muted"><i class="bi bi-person"></i> Added by: @book.UserName</small>
                            <small class="text-muted"><i class="bi bi-calendar"></i> On: @(book.FavoriteDate?.ToString("dd/MM/yyyy") ?? "-")</small>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-heartbreak empty-icon"></i>
                <h3>No favorites yet</h3>
                <p>You haven't added any books to your favorites. Start exploring our library!</p>
                <a href="@Url.Action("Index", "Library")" class="btn-explore">Explore Library</a>
            </div>
        }
    </div>
</div>

<style>
    /* =========================================================
       PREMIUM FAVORITES PAGE DESIGN
       ========================================================= */
    .favorite-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem;
    }

    .favorite-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #00B4D8 100%);
        border-radius: 20px;
        padding: 2.5rem 2rem;
        color: #fff;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0, 180, 216, 0.2);
        margin-bottom: 2rem;
    }

    .favorite-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 0.3rem;
    }

    .favorite-subtitle {
        color: rgba(255,255,255,0.8);
        font-size: 1rem;
        margin: 0;
    }

    .favorite-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 2rem;
    }

    .favorite-card {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.04);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .favorite-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    .card-image-wrap {
        position: relative;
        height: 320px;
        background: #f8f9fa;
        overflow: hidden;
    }

    .book-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .favorite-card:hover .book-cover {
        transform: scale(1.05);
    }

    .no-image-cover {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #e9ecef 0%, #f8f9fa 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #adb5bd;
    }

    .btn-unlike {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(5px);
        color: #e63946;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        z-index: 10;
        opacity: 0.9;
    }

    .btn-unlike:hover {
        background: #fff;
        color: #d62828;
        transform: scale(1.05);
        opacity: 1;
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .card-content h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0 0 0.3rem;
        line-height: 1.3;
    }

    .author {
        color: #6c757d;
        font-size: 0.9rem;
        margin: 0;
    }

    .card-divider {
        margin: 1rem 0;
        border-color: rgba(0,0,0,0.05);
    }

    .card-meta {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        font-size: 0.8rem;
        margin-top: auto;
    }

    /* Empty State */
    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 5rem 2rem;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
    }

    .empty-icon {
        font-size: 4rem;
        color: #dee2e6;
        margin-bottom: 1rem;
        display: block;
    }

    .empty-state h3 {
        font-family: 'Playfair Display', serif;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #6c757d;
        margin-bottom: 2rem;
    }

    .btn-explore {
        display: inline-block;
        background: #00B4D8;
        color: #fff;
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 180, 216, 0.3);
    }

    .btn-explore:hover {
        background: #0096b7;
        color: #fff;
        transform: translateY(-2px);
    }

    /* Cart FAB in Profile */
    .cart-link {
        position: fixed; bottom: 30px; right: 30px;
        background: #00B4D8; color: #fff;
        width: 56px; height: 56px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; margin: 0;
        box-shadow: 0 5px 20px rgba(0, 180, 216, 0.4);
        z-index: 1000;
    }
    .cart-count {
        position: absolute; top: -5px; right: -5px;
        background: #e63946; color: #fff; border-radius: 50%;
        width: 22px; height: 22px; font-size: 0.75rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
    }
</style>

<script>
    function toggleFavorite(button) {
        const bookId = $(button).data("book-id");

        $.ajax({
            url: '/Library/ToggleFavorite',
            type: 'POST',
            data: { bookId: bookId },
            success: function (response) {
                if (response.success) {
                    // הסרת הספר מהרשימה אם הלב נלחץ
                    if (!response.isFavorite) {
                        $(button).closest('.favorite-card').fadeOut(300, function () {
                            $(this).remove();
                            // Optional: Reload if empty, but visually it works great as is.
                        });
                    }
                }
            },
            error: function () {
                alert('Error communicating with the server.');
            }
        });
    }
</script>
